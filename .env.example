# Docker Compose template environment (safe to commit)
# Copy to .env and fill in real values.

# Service endpoints
API_URL=http://database:4000

# Database service
HOST=0.0.0.0
PORT=4000
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Firebase / Google Cloud
FIREBASE_DATABASE_URL=https://example-project-default-rtdb.firebaseio.com
FIREBASE_SERVICE_ACCOUNT_KEY_FILE=/run/secrets/service_account_key
GOOGLE_STORAGE_SERVICE_ACCOUNT_KEY_FILE=/run/secrets/service_account_key
GOOGLE_STORAGE_BUCKET_NAME=example-bucket
GOOGLE_STORAGE_PROJECT_ID=example-project-id

# Optional keys / secrets
LEASE_KEY=
ADMIN_PUBLIC_KEY=
FIREBASE_SERVICE_ACCOUNT_KEY_STRING=
GOOGLE_STORAGE_SERVICE_ACCOUNT_KEY_STRING=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
FIREBASE_API_KEY=
CLAUDE_API_KEY=
FEEDBACK_WEBHOOK_URL=

# Host path for service account JSON mounted into containers
SERVICE_ACCOUNT_KEY_HOST_FILE=./service_account_key.json
