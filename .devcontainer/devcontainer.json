{
  "name": "Simulator Dev",
  "dockerComposeFile": [
    "../docker-compose.yml"
  ],
  "service": "frontend",
  "runServices": [
    "redis",
    "database",
    "frontend"
  ],
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "remoteUser": "node",
  "forwardPorts": [
    8080,
    4000,
    6379
  ]
}
