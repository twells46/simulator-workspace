+let isShuttingDown = false;
+
+const shutdown = async (signal: NodeJS.Signals) => {
+  if (isShuttingDown) return;
+  isShuttingDown = true;
+
+  app.log.info({ signal }, 'Shutting down database service');
+
+  try {
+    await app.close();
+    await cache.close();
+    process.exit(0);
+  } catch (error) {
+    app.log.error({ error, signal }, 'Failed to shut down database service cleanly');
+    process.exit(1);
+  }
+};
+
+process.on('SIGINT', () => {
+  void shutdown('SIGINT');
+});
+
+process.on('SIGTERM', () => {
+  void shutdown('SIGTERM');
+});
+
+main().catch((error) => {
+  app.log.error({ error }, 'Failed to start database service');
+  process.exit(1);
+});
